APP_ENV=local
SERVICE_NAME=dispatch-api
LOG_LEVEL=INFO
SECRET_KEY=dispatch-local-secret
DATABASE_URL=postgresql+asyncpg://postgres:khalid123@postgres:5432/dispatch
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
REDIS_URL=redis://redis:6379/0
AWS_REGION=us-east-1
SES_REGION=us-east-1
SES_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:dispatch-local-events
LOCALSTACK_ENDPOINT_URL=http://localstack:4566
DEFAULT_DOMAIN_HOURLY_RATE_LIMIT=150
DEFAULT_CAMPAIGN_HOURLY_RATE_LIMIT=100
BOUNCE_RATE_ALARM=0.015
COMPLAINT_RATE_ALARM=0.0005
ML_SCORER_ENABLED=false
REPLY_INTENT_ENABLED=false
ANOMALY_DETECTION_ENABLED=false
SESSION_COOKIE_NAME=dispatch_session
SESSION_TTL_SECONDS=1209600
MFA_CHALLENGE_TTL_SECONDS=300
MFA_ENROLLMENT_TTL_SECONDS=600
MFA_KMS_DATA_KEY=
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=900
AUTH_LOGIN_ATTEMPT_WINDOW_SECONDS=900
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2
